# Umi / harness 环境变量（复制为 .env 后修改）

# 开发代理目标（/api、/springai）
API_PROXY_TARGET=http://localhost:8080

# 生产 API 基址（留空则走相对路径 / 代理）
API_BASE=

# true = 聊天 SSE 使用前端 mock 流
MOCK_CHAT=false

# 智能体模式 Header X-Tenant-Id
SUPER_AGENTS_TENANT_ID=default

# OpenAPI 类型生成（springdoc）；不可用时见 openapi-spec/agent-hub.fragment.yaml
OPENAPI_SCHEMA_URL=http://localhost:8080/v3/api-docs
